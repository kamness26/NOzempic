# ─────────────────────────────────────────────
#  NOzempic — Environment Variables
#  Copy this to .env and fill in your values.
#  NEVER commit .env to GitHub.
# ─────────────────────────────────────────────

# ── ANTHROPIC (Claude API) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── OURA (Kam) ──
# Get from: cloud.ouraring.com → Account → Personal Access Tokens
OURA_PERSONAL_ACCESS_TOKEN=

# ── WHOOP (Marcus) ──
# Get from: developer.whoop.com → your app credentials
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8080/whoop/callback
# After running onboarding/whoop_auth.py, these are stored automatically:
WHOOP_ACCESS_TOKEN=
WHOOP_REFRESH_TOKEN=

# ── EMAIL DELIVERY (Gmail) ──
# Create a dedicated Gmail: e.g. nozempic.coach@gmail.com
# Enable 2-Step Verification, then generate an App Password:
#   Google Account → Security → App Passwords → name it "NOzempic"
GMAIL_ADDRESS=nozempic.coach@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── GROUP CONFIG ──
# Comma-separated list of participant emails
PARTICIPANT_EMAILS=kam@example.com,marcus@example.com
ADMIN_EMAIL=kam@example.com
GROUP_NAME=NOzempic
